# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=rg-doc-intelligence
AZURE_LOCATION=southeastasia

# Document Intelligence Service
DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-doc-intel-endpoint.cognitiveservices.azure.com/
# Leave empty to use managed identity, or provide key for development
DOCUMENT_INTELLIGENCE_KEY=

# Storage Account
STORAGE_ACCOUNT_NAME=your-storage-account-name
STORAGE_CONTAINER_SOURCE=source-documents
STORAGE_CONTAINER_RESULTS=results
STORAGE_CONTAINER_TRANSLATIONS=translations
# Leave empty to use managed identity, or provide connection string for development
STORAGE_CONNECTION_STRING=

# Key Vault (for production secrets)
KEY_VAULT_NAME=kv-doc-intel
KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# Processing Options
BATCH_SIZE_LIMIT=10000
SUPPORTED_FORMATS=.pdf,.docx,.xlsx,.pptx,.png,.jpg,.jpeg,.tiff,.bmp,.html,.txt
MAX_FILE_SIZE_MB=100
PARALLEL_UPLOAD_WORKERS=4

# Blob Upload Configuration
BLOB_MAX_BLOCK_SIZE=4194304
BLOB_MAX_SINGLE_PUT_SIZE=8388608
BLOB_UPLOAD_CONCURRENCY=2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/docprocessor.log

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2
RETRY_INITIAL_WAIT_SECONDS=1

# Optional: Azure Translator (Phase 2)
TRANSLATOR_ENDPOINT=
TRANSLATOR_KEY=
TRANSLATOR_REGION=
TRANSLATION_DEFAULT_LOCALES=en,nb-NO,es-ES,ko-KR,zh-Hans,id-ID,ja-JP,fr-FR,vi-VN,zh-Hant-TW
TRANSLATION_OVERWRITE_EXISTING=false
TRANSLATION_MAX_CHARS_PER_REQUEST=4500
TRANSLATION_REQUEST_BATCH_SIZE=20

# Optional: Azure OpenAI (Phase 3)
OPENAI_ENDPOINT=
OPENAI_KEY=
OPENAI_DEPLOYMENT_NAME=

# Optional: app update manifest override for development/custom deployments
DOC_PROCESSOR_UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/benoit-nguyen/dnv-sng-az-doc-intelligence/main/update-manifest.json
DOC_PROCESSOR_UPDATE_RELEASES_URL=https://github.com/benoit-nguyen/dnv-sng-az-doc-intelligence/releases/latest
